# Postgres connection string for your hosted database
DATABASE_URL=postgresql://username:password@host:5432/database

# JWT config used by backend login/auth protection
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=https://your-site.netlify.app,http://localhost:3000

# Cloudinary credentials (for resume upload feature)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
